{
  "openapi": "3.1.1",
  "info": {
    "title": "Host | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5225/"
    }
  ],
  "paths": {
    "/courses": {
      "get": {
        "tags": [
          "Host"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogDto"
                }
              }
            }
          }
        }
      }
    },
    "/lessons/{lessonId}": {
      "get": {
        "tags": [
          "Host"
        ],
        "parameters": [
          {
            "name": "lessonId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/lessons/{lessonId}/attempts": {
      "post": {
        "tags": [
          "Host"
        ],
        "parameters": [
          {
            "name": "lessonId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AttemptBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/me/courses/{courseId}/map": {
      "get": {
        "tags": [
          "Host"
        ],
        "parameters": [
          {
            "name": "courseId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/me/xp": {
      "get": {
        "tags": [
          "Host"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/me/timezone": {
      "put": {
        "tags": [
          "Host"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SetTimeZoneRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/me/streak": {
      "get": {
        "tags": [
          "Host"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/me/league": {
      "get": {
        "tags": [
          "Host"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/leagues/weeks/{weekStart}/settle": {
      "post": {
        "tags": [
          "Host"
        ],
        "parameters": [
          {
            "name": "weekStart",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/me/streak-freezes": {
      "post": {
        "tags": [
          "Host"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnswerBody": {
        "required": [
          "exerciseId",
          "selectedChoiceIndex"
        ],
        "type": "object",
        "properties": {
          "exerciseId": {
            "type": "string",
            "format": "uuid"
          },
          "selectedChoiceIndex": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "AttemptBody": {
        "required": [
          "answers"
        ],
        "type": "object",
        "properties": {
          "answers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AnswerBody"
            }
          }
        }
      },
      "CatalogDto": {
        "required": [
          "courses"
        ],
        "type": "object",
        "properties": {
          "courses": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CourseDto"
            }
          }
        }
      },
      "CourseDto": {
        "required": [
          "id",
          "title",
          "language",
          "units"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "language": {
            "type": [
              "null",
              "string"
            ]
          },
          "units": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UnitDto"
            }
          }
        }
      },
      "LessonDto": {
        "required": [
          "id",
          "title",
          "position",
          "isPublished"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "position": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "isPublished": {
            "type": "boolean"
          }
        }
      },
      "SetTimeZoneRequest": {
        "required": [
          "ianaId"
        ],
        "type": "object",
        "properties": {
          "ianaId": {
            "type": "string"
          }
        }
      },
      "UnitDto": {
        "required": [
          "id",
          "title",
          "position",
          "lessons"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "position": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "lessons": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LessonDto"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Host"
    }
  ]
}